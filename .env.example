# ─── Connection ───────────────────────────────────────────────────────────────
POSTGRESQL_CONNECTION_STRING="postgresql://user:password@localhost:5432/mydb"

# ─── Security Profile ────────────────────────────────────────────────────────
# Options: general (permissive), text2sql (strict), sensitive (strict + require policy)
SECURITY_PROFILE=general

# ─── Write Policy ────────────────────────────────────────────────────────────
READ_ONLY=true
ALLOW_DESTRUCTIVE=false
ENABLE_WRITE_TOOLS=false
# WRITE_ALLOWLIST=public.users,public.orders,staging.*

# ─── Query Guardrails ────────────────────────────────────────────────────────
DEFAULT_LIMIT=100
MAX_LIMIT=1000
MAX_QUERY_LENGTH=10000
QUERY_TIMEOUT_SECONDS=300

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_MAX_CALLS=100
RATE_LIMIT_WINDOW_SECONDS=3600

# ─── PII Masking ─────────────────────────────────────────────────────────────
# PII_RULES=[{"column":"email","method":"hash"},{"column":"ssn","method":"redact"}]

# ─── Phase 10: SQL Security Hardening ────────────────────────────────────────
BLOCK_SELECT_STAR=true
BLOCK_SUBQUERIES=true
ALLOW_CTE=false
ALLOW_SET_OPERATIONS=false
ALLOW_RECURSIVE_CTE=false

# Column policy — inline JSON or file path
# COLUMN_POLICY={"public.users":{"allowed_columns":["id","name","email"],"sampleable_columns":["status"],"required_filter_columns":["id"]}}
# COLUMN_POLICY_FILE=/path/to/policy.json
# COLUMN_POLICY_MODE=permissive

# Function control — JSON array of allowed functions (for text2sql/sensitive)
# ALLOWED_FUNCTIONS=["count","sum","avg","min","max","coalesce","date_trunc","round"]

# LIMIT / OFFSET / Result budget
MAX_OFFSET=10000
MAX_RESULT_ROWS=100
MAX_RESULT_BYTES=1048576
MAX_CELL_LENGTH=4096
MAX_COLUMNS_RETURNED=50

# EXPLAIN control
# BLOCK_EXPLAIN=false
BLOCK_EXPLAIN_ANALYZE=true

# Schema defaults
DEFAULT_SCHEMA=public

# User context for Row-Level Security
# USER_CONTEXT_VARIABLE=app.current_user_id

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
