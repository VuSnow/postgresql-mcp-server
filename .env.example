POSTGRESQL_CONNECTION_STRING="postgresql://user:password@localhost:5432/mydb"
READ_ONLY=true
ALLOW_DESTRUCTIVE=false
# WRITE_ALLOWLIST=public.users,public.orders,staging.*
DEFAULT_LIMIT=100
MAX_LIMIT=1000
MAX_QUERY_LENGTH=10000
QUERY_TIMEOUT_SECONDS=300
RATE_LIMIT_MAX_CALLS=100
RATE_LIMIT_WINDOW_SECONDS=3600
# PII_RULES=[{"column":"email","method":"hash"},{"column":"ssn","method":"redact"}]
LOG_LEVEL=INFO
